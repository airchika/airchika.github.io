---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog/', label: '文章' },
  { href: '/about/', label: '关于' },
];
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Air Chika 首页">
    <span class="brand-mark" aria-hidden="true">A</span>
    <span>Air Chika</span>
  </a>
  <nav class="site-nav" aria-label="主导航">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
